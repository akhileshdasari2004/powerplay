# MongoDB
# Format: mongodb+srv://<username>:<password>@<host>/<database>
# Must include username and password credentials
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xzy.mongodb.net/powerplay

# Server
PORT=5000
NODE_ENV=development

# CORS
# Whitelist for development (Vite default + CRA fallback)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000